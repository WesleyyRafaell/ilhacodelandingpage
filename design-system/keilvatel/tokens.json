    "purpleRadialFull": {
      "css": "radial-gradient(at top left, #CAB5FF 0%, #6E59A4 100%)",
      "usage": "Footer newsletter band"
    },
    "purpleRadialPanel": {
      "css": "radial-gradient(at center center, #CAB5FF 0%, #6E59A4 100%)",
      "usage": "Image panels behind cutout portraits"
    },
    "purpleRadialHero": {
      "css": "radial-gradient(at center right, #CAB5FF 0%, #6E59A4 100%)",
      "usage": "Hero portrait panel"
    }
