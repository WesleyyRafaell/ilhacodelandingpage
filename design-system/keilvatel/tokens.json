  "typography": {
    "fontFamilies": {
      "heading": "Work Sans",
      "body": "Roboto",
      "button": "Work Sans",
      "nav": "Work Sans"
    },
    "desktop": {
      "h1": { "fontSize": "46px", "fontWeight": 600, "lineHeight": "1.3em" },
      "h2": { "fontSize": "38px", "fontWeight": 600, "lineHeight": "1.3em" },
      "h3": { "fontSize": "26px", "fontWeight": 600 },
      "h4": { "fontSize": "24px", "fontWeight": 600 },
      "subtitle": { "fontSize": "20px", "fontWeight": 500 },
      "body": { "fontSize": "16px", "fontWeight": 400 },
      "small": { "fontSize": "14px", "fontWeight": 400 },
      "button": { "fontSize": "16px", "fontWeight": 600, "letterSpacing": "0.2px" },
      "price": { "fontSize": "50px", "fontWeight": 600, "lineHeight": "1.3em" },
      "testimonialQuote": { "fontSize": "23px", "fontWeight": 400, "fontStyle": "italic", "lineHeight": "1.5em" },
      "largeDisplay": { "fontSize": "65px", "fontWeight": 600, "lineHeight": "1.3em" },
      "megaDisplay": { "fontSize": "90px", "fontWeight": 600, "lineHeight": "1.3em" }
    },
    "tablet": {
      "h2": "36px",
      "price": "48px",
      "testimonialQuote": "20px",
      "largeDisplay": "60px",
      "megaDisplay": "60px"
    },
    "mobile": {
      "h1": "44px",
      "h2": "34px",
      "body": "14px",
      "button": "14px",
      "subtitle": "18px",
      "h3": "24px",
      "h4": "20px",
      "price": "46px",
      "testimonialQuote": "18px",
      "largeDisplay": "50px",
      "megaDisplay": "50px"
    }
  },
  "layout": {
    "containerMaxWidth": "1190px",
    "elementorDefaultContainer": "1140px",
    "breakpoints": {
      "mobileMax": "767px",
      "tabletMax": "1024px",
      "desktopMin": "1025px"
    },
    "heroColumns": {
      "content": "44%",
      "visual": "56%"
    },
    "commonColumns": {
      "split": "50% / 50%",
      "thirds": "33% / 33% / 33%",
      "quarters": "25% / 25% / 25% / 25%"
    },
    "sectionPadding": {
      "standardDesktop": "100px 0",
      "largeDesktop": "180px 0",
      "mediumDesktop": "120px 0 50px",
      "tablet": "80px 20px",
      "mobile": "50px 20px"
    }
  },
  "shape": {
    "radius": {
      "button": "10px",
      "input": "10px",
      "dropdown": "10px",
      "card": "20px",
      "header": "20px",
      "imagePanel": "0 0 130px 130px",
      "circle": "50%"
    },
    "borders": {
      "input": "2px solid #EBE8F4",
      "inputFocus": "2px solid #FBB53E",
      "cardLight": "2px solid #F7F4FF",
      "serviceCardDark": "2px solid #5A4591",
      "footerDivider": "2px solid #5A4591"
    }
  },
  "spacing": {
    "buttonPadding": "15px 30px",
    "newsletterInputPadding": "20px 30px",
    "serviceCardPadding": "50px 40px 10px",
    "serviceCardHoverPadding": "30px 40px",
    "pricingCardPadding": "30px",
    "blogContentPadding": "20px",
    "testimonialPadding": "20px 30px 10px",
    "headerPadding": "20px 30px",
    "iconGap": "20px",
    "widgetGap": "20px"
  },
  "effects": {
    "buttonHover": {
      "transform": "translate(5px, -5px)",
      "shadow": "-8px 8px 0 0 #F7F4FF"
    },
    "footerButtonHover": {
      "transform": "translate(5px, -5px)",
      "shadow": "-8px 8px 0 0 rgba(245, 242, 255, 0.17)"
    },
    "cardHover": {
      "transform": "rotate(-1deg)",
      "background": "#5A4591",
      "transition": "0.3s"
    },
    "navHover": {
      "color": "#FBB53E",
      "borderBottom": "1px solid #FBB53E",
      "transitionDuration": "0.7s"
    },
    "dropdownShadow": "0 10px 30px rgba(157, 115, 27, 0.1)"
  },
  "motion": {
    "entryAnimations": ["fadeInUp", "fadeInLeft", "fadeInRight"],
    "entryTiming": "animated-slow",
    "commonDelaysMs": [100, 200, 300, 700],
    "testimonialAutoplayMs": 3500,
    "chartAnimationDurationMs": 3600,
    "mobileMenuTransition": "left .6s cubic-bezier(.6,.1,.68,.53), width .6s"
  }
}
